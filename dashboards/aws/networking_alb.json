{
  "label": "beta",
  "metric_keys": [
    "aws_applicationelb_request_count"
  ],
  "dashboard": {
    "title": "AWS/ApplicationELB",
    "description": "Monitor Application Load Balancer request counts, response times, HTTP status codes, host health, and connection metrics.",
    "visuals": [
      {
        "type": "timeseries",
        "display": "line",
        "format": "number",
        "draw_null_as_zero": true,
        "title": "Request Count",
        "description": "The number of requests processed over IPv4 and IPv6.",
        "line_label": "%name% %LoadBalancer%",
        "metrics": [
          {
            "name": "aws_applicationelb_request_count",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "LoadBalancer", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "duration",
        "format_input": "second",
        "draw_null_as_zero": false,
        "title": "Target Response Time",
        "description": "The time elapsed after the request leaves the load balancer until a response from the target is received.",
        "line_label": "%name% %LoadBalancer%",
        "metrics": [
          {
            "name": "aws_applicationelb_target_response_time",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "LoadBalancer", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "number",
        "draw_null_as_zero": true,
        "title": "HTTP Target 2xx vs 3xx vs 4xx vs 5xx",
        "description": "The number of HTTP response codes generated by registered targets, grouped by class.",
        "line_label": "%name% %LoadBalancer%",
        "metrics": [
          {
            "name": "aws_applicationelb_httpcode_target_2xx_count",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "LoadBalancer", "value": "*" }]
          },
          {
            "name": "aws_applicationelb_httpcode_target_3xx_count",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "LoadBalancer", "value": "*" }]
          },
          {
            "name": "aws_applicationelb_httpcode_target_4xx_count",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "LoadBalancer", "value": "*" }]
          },
          {
            "name": "aws_applicationelb_httpcode_target_5xx_count",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "LoadBalancer", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "number",
        "draw_null_as_zero": true,
        "title": "HTTP ELB 4xx vs 5xx",
        "description": "The number of HTTP 4xx/5xx error codes generated by the load balancer itself.",
        "line_label": "%name% %LoadBalancer%",
        "metrics": [
          {
            "name": "aws_applicationelb_httpcode_elb_4xx_count",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "LoadBalancer", "value": "*" }]
          },
          {
            "name": "aws_applicationelb_httpcode_elb_5xx_count",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "LoadBalancer", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "number",
        "draw_null_as_zero": false,
        "title": "Healthy vs Unhealthy Hosts",
        "description": "The number of targets that are considered healthy/unhealthy.",
        "line_label": "%name% %TargetGroup%",
        "metrics": [
          {
            "name": "aws_applicationelb_healthy_host_count",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "TargetGroup", "value": "*" }]
          },
          {
            "name": "aws_applicationelb_un_healthy_host_count",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "TargetGroup", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "number",
        "draw_null_as_zero": true,
        "title": "Active vs New Connections",
        "description": "The total number of concurrent active TCP connections / new TCP connections established from clients to the load balancer.",
        "line_label": "%name% %LoadBalancer%",
        "metrics": [
          {
            "name": "aws_applicationelb_active_connection_count",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "LoadBalancer", "value": "*" }]
          },
          {
            "name": "aws_applicationelb_new_connection_count",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "LoadBalancer", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "size",
        "format_input": "byte",
        "draw_null_as_zero": true,
        "title": "Processed Bytes",
        "description": "The total number of bytes processed by the load balancer over IPv4 and IPv6.",
        "line_label": "%name% %LoadBalancer%",
        "metrics": [
          {
            "name": "aws_applicationelb_processed_bytes",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "LoadBalancer", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "number",
        "draw_null_as_zero": true,
        "title": "Consumed LCUs",
        "description": "The number of load balancer capacity units (LCU) used by the load balancer.",
        "line_label": "%name% %LoadBalancer%",
        "metrics": [
          {
            "name": "aws_applicationelb_consumed_lcus",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "LoadBalancer", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "number",
        "draw_null_as_zero": true,
        "title": "Target Connection Errors",
        "description": "The number of connections that were not successfully established between the load balancer and target.",
        "line_label": "%name% %LoadBalancer%",
        "metrics": [
          {
            "name": "aws_applicationelb_target_connection_error_count",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "LoadBalancer", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "number",
        "draw_null_as_zero": true,
        "title": "Rejected Connections",
        "description": "The number of connections rejected because the load balancer reached its maximum number of connections.",
        "line_label": "%name% %LoadBalancer%",
        "metrics": [
          {
            "name": "aws_applicationelb_rejected_connection_count",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "LoadBalancer", "value": "*" }]
          }
        ]
      }
    ]
  }
}
