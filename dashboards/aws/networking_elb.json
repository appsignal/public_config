{
  "label": "beta",
  "metric_keys": [
    "aws_elb_request_count"
  ],
  "dashboard": {
    "title": "AWS/ELB",
    "description": "Monitor Classic Elastic Load Balancer request counts, latency, HTTP status codes, host health, and queue metrics.",
    "visuals": [
      {
        "type": "timeseries",
        "display": "line",
        "format": "number",
        "draw_null_as_zero": true,
        "title": "Request Count",
        "description": "The number of requests completed or connections made during the specified interval.",
        "line_label": "%name% %LoadBalancerName%",
        "metrics": [
          {
            "name": "aws_elb_request_count",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "LoadBalancerName", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "duration",
        "format_input": "second",
        "draw_null_as_zero": false,
        "title": "Latency",
        "description": "The total time elapsed from when the load balancer sent the request to a registered instance until the instance started to send the response headers.",
        "line_label": "%name% %LoadBalancerName%",
        "metrics": [
          {
            "name": "aws_elb_latency",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "LoadBalancerName", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "number",
        "draw_null_as_zero": true,
        "title": "HTTP Backend 2xx vs 3xx vs 4xx vs 5xx",
        "description": "The number of HTTP response codes generated by registered instances, grouped by class.",
        "line_label": "%name% %LoadBalancerName%",
        "metrics": [
          {
            "name": "aws_elb_httpcode_backend_2xx",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "LoadBalancerName", "value": "*" }]
          },
          {
            "name": "aws_elb_httpcode_backend_3xx",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "LoadBalancerName", "value": "*" }]
          },
          {
            "name": "aws_elb_httpcode_backend_4xx",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "LoadBalancerName", "value": "*" }]
          },
          {
            "name": "aws_elb_httpcode_backend_5xx",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "LoadBalancerName", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "number",
        "draw_null_as_zero": true,
        "title": "HTTP ELB 4xx vs 5xx",
        "description": "The number of HTTP 4xx/5xx error codes generated by the load balancer itself.",
        "line_label": "%name% %LoadBalancerName%",
        "metrics": [
          {
            "name": "aws_elb_httpcode_elb_4xx",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "LoadBalancerName", "value": "*" }]
          },
          {
            "name": "aws_elb_httpcode_elb_5xx",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "LoadBalancerName", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "number",
        "draw_null_as_zero": false,
        "title": "Healthy vs Unhealthy Hosts",
        "description": "The number of healthy/unhealthy instances registered with the load balancer.",
        "line_label": "%name% %LoadBalancerName%",
        "metrics": [
          {
            "name": "aws_elb_healthy_host_count",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "LoadBalancerName", "value": "*" }]
          },
          {
            "name": "aws_elb_un_healthy_host_count",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "LoadBalancerName", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "number",
        "draw_null_as_zero": true,
        "title": "Surge Queue Length vs Spillover Count",
        "description": "The total number of requests pending routing (queue) and the total number of requests rejected because the surge queue is full (spillover).",
        "line_label": "%name% %LoadBalancerName%",
        "metrics": [
          {
            "name": "aws_elb_surge_queue_length",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "LoadBalancerName", "value": "*" }]
          },
          {
            "name": "aws_elb_spillover_count",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "LoadBalancerName", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "number",
        "draw_null_as_zero": true,
        "title": "Backend Connection Errors",
        "description": "The number of connections that were not successfully established between the load balancer and the registered instances.",
        "line_label": "%name% %LoadBalancerName%",
        "metrics": [
          {
            "name": "aws_elb_backend_connection_errors",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "LoadBalancerName", "value": "*" }]
          }
        ]
      }
    ]
  }
}
