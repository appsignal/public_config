{
  "label": "beta",
  "metric_keys": [
    "aws_lambda_invocations"
  ],
  "dashboard": {
    "title": "AWS/Lambda",
    "description": "Monitor AWS Lambda function invocations, errors, throttles, duration, and concurrency.",
    "visuals": [
      {
        "type": "timeseries",
        "display": "line",
        "format": "number",
        "draw_null_as_zero": true,
        "title": "Invocations",
        "description": "The number of times the function code is invoked, including successful invocations and invocations that result in a function error.",
        "line_label": "%name% %FunctionName%",
        "metrics": [
          {
            "name": "aws_lambda_invocations",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "FunctionName", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "number",
        "draw_null_as_zero": true,
        "title": "Errors",
        "description": "The number of invocations that result in a function error, including exceptions thrown by the code and runtime errors.",
        "line_label": "%name% %FunctionName%",
        "metrics": [
          {
            "name": "aws_lambda_errors",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "FunctionName", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "number",
        "draw_null_as_zero": true,
        "title": "Throttles",
        "description": "The number of invocation requests that are throttled because no concurrency is available.",
        "line_label": "%name% %FunctionName%",
        "metrics": [
          {
            "name": "aws_lambda_throttles",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "FunctionName", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "duration",
        "draw_null_as_zero": false,
        "title": "Duration",
        "description": "The amount of time that the function code spends processing an event. The billed duration is rounded up to the nearest millisecond.",
        "line_label": "%name% %FunctionName%",
        "metrics": [
          {
            "name": "aws_lambda_duration",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "FunctionName", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "number",
        "draw_null_as_zero": true,
        "title": "ConcurrentExecutions vs UnreservedConcurrentExecutions",
        "description": "The number of function instances processing events simultaneously. Unreserved excludes functions with provisioned concurrency.",
        "line_label": "%name% %FunctionName%",
        "metrics": [
          {
            "name": "aws_lambda_concurrent_executions",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "FunctionName", "value": "*" }]
          },
          {
            "name": "aws_lambda_unreserved_concurrent_executions",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "FunctionName", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "number",
        "draw_null_as_zero": true,
        "title": "ClaimedAccountConcurrency",
        "description": "The amount of concurrency that is unavailable for on-demand invocations. Equal to allocated concurrency for all functions with reserved or provisioned concurrency.",
        "line_label": "%name%",
        "metrics": [
          {
            "name": "aws_lambda_claimed_account_concurrency",
            "fields": [{ "field": "GAUGE" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "number",
        "draw_null_as_zero": true,
        "title": "AsyncEventsReceived vs AsyncEventsDropped",
        "description": "The number of events that Lambda successfully queued for async processing vs. dropped without processing.",
        "line_label": "%name% %FunctionName%",
        "metrics": [
          {
            "name": "aws_lambda_async_events_received",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "FunctionName", "value": "*" }]
          },
          {
            "name": "aws_lambda_async_events_dropped",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "FunctionName", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "duration",
        "draw_null_as_zero": false,
        "title": "AsyncEventAge",
        "description": "The time between when Lambda successfully queues the event and when the function is invoked.",
        "line_label": "%name% %FunctionName%",
        "metrics": [
          {
            "name": "aws_lambda_async_event_age",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "FunctionName", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "duration",
        "draw_null_as_zero": false,
        "title": "Iterator Age",
        "description": "Age of the last record processed from a stream event source (Kinesis, DynamoDB Streams). Increasing values indicate the consumer is falling behind.",
        "line_label": "%name% %FunctionName%",
        "metrics": [
          {
            "name": "aws_lambda_iterator_age",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "FunctionName", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "number",
        "draw_null_as_zero": true,
        "title": "Dead Letter Errors vs Destination Delivery Failures",
        "description": "Failed attempts to send events to dead-letter queues or configured destinations.",
        "line_label": "%name% %FunctionName%",
        "metrics": [
          {
            "name": "aws_lambda_dead_letter_errors",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "FunctionName", "value": "*" }]
          },
          {
            "name": "aws_lambda_destination_delivery_failures",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "FunctionName", "value": "*" }]
          }
        ]
      }
    ]
  }
}
