{
  "label": "beta",
  "metric_keys": [
    "aws_rds_cpu_utilization"
  ],
  "dashboard": {
    "title": "AWS/RDS",
    "description": "Monitor Amazon RDS database instance performance including CPU, connections, storage, I/O, and replication metrics.",
    "visuals": [
      {
        "type": "timeseries",
        "display": "line",
        "format": "percent",
        "draw_null_as_zero": true,
        "title": "CPU Utilization",
        "description": "The percentage of CPU utilization for the DB instance.",
        "line_label": "%name% %DBInstanceIdentifier%",
        "metrics": [
          {
            "name": "aws_rds_cpu_utilization",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "DBInstanceIdentifier", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "number",
        "draw_null_as_zero": true,
        "title": "Database Connections",
        "description": "The number of client network connections to the database instance.",
        "line_label": "%name% %DBInstanceIdentifier%",
        "metrics": [
          {
            "name": "aws_rds_database_connections",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "DBInstanceIdentifier", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "size",
        "format_input": "byte",
        "draw_null_as_zero": true,
        "title": "Freeable Memory",
        "description": "The amount of available random access memory.",
        "line_label": "%name% %DBInstanceIdentifier%",
        "metrics": [
          {
            "name": "aws_rds_freeable_memory",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "DBInstanceIdentifier", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "size",
        "format_input": "byte",
        "draw_null_as_zero": true,
        "title": "Free Storage Space",
        "description": "The amount of available storage space.",
        "line_label": "%name% %DBInstanceIdentifier%",
        "metrics": [
          {
            "name": "aws_rds_free_storage_space",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "DBInstanceIdentifier", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "number",
        "draw_null_as_zero": true,
        "title": "Read IOPS vs Write IOPS",
        "description": "The average number of disk read/write I/O operations per second.",
        "line_label": "%name% %DBInstanceIdentifier%",
        "metrics": [
          {
            "name": "aws_rds_read_iops",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "DBInstanceIdentifier", "value": "*" }]
          },
          {
            "name": "aws_rds_write_iops",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "DBInstanceIdentifier", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "duration",
        "format_input": "second",
        "draw_null_as_zero": false,
        "title": "Read Latency vs Write Latency",
        "description": "The average amount of time taken per disk read/write I/O operation.",
        "line_label": "%name% %DBInstanceIdentifier%",
        "metrics": [
          {
            "name": "aws_rds_read_latency",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "DBInstanceIdentifier", "value": "*" }]
          },
          {
            "name": "aws_rds_write_latency",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "DBInstanceIdentifier", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "throughput",
        "format_input": "byte",
        "draw_null_as_zero": true,
        "title": "Read Throughput vs Write Throughput",
        "description": "The average number of bytes read from/written to disk per second.",
        "line_label": "%name% %DBInstanceIdentifier%",
        "metrics": [
          {
            "name": "aws_rds_read_throughput",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "DBInstanceIdentifier", "value": "*" }]
          },
          {
            "name": "aws_rds_write_throughput",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "DBInstanceIdentifier", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "number",
        "draw_null_as_zero": true,
        "title": "Disk Queue Depth",
        "description": "The number of outstanding I/O requests waiting to access the disk.",
        "line_label": "%name% %DBInstanceIdentifier%",
        "metrics": [
          {
            "name": "aws_rds_disk_queue_depth",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "DBInstanceIdentifier", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "size",
        "format_input": "byte",
        "draw_null_as_zero": true,
        "title": "Swap Usage",
        "description": "The amount of swap space used on the DB instance.",
        "line_label": "%name% %DBInstanceIdentifier%",
        "metrics": [
          {
            "name": "aws_rds_swap_usage",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "DBInstanceIdentifier", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "throughput",
        "format_input": "byte",
        "draw_null_as_zero": true,
        "title": "Network Receive vs Transmit Throughput",
        "description": "The incoming/outgoing network traffic on the DB instance.",
        "line_label": "%name% %DBInstanceIdentifier%",
        "metrics": [
          {
            "name": "aws_rds_network_receive_throughput",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "DBInstanceIdentifier", "value": "*" }]
          },
          {
            "name": "aws_rds_network_transmit_throughput",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "DBInstanceIdentifier", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "duration",
        "format_input": "second",
        "draw_null_as_zero": false,
        "title": "Replica Lag",
        "description": "The amount of time a read replica DB instance lags behind the source DB instance.",
        "line_label": "%name% %DBInstanceIdentifier%",
        "metrics": [
          {
            "name": "aws_rds_replica_lag",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "DBInstanceIdentifier", "value": "*" }]
          }
        ]
      },
      {
        "type": "timeseries",
        "display": "line",
        "format": "percent",
        "draw_null_as_zero": false,
        "title": "Burst Balance",
        "description": "Percentage of I/O burst credits remaining. Available for instances with gp2 storage.",
        "line_label": "%name% %DBInstanceIdentifier%",
        "metrics": [
          {
            "name": "aws_rds_burst_balance",
            "fields": [{ "field": "GAUGE" }],
            "tags": [{ "key": "DBInstanceIdentifier", "value": "*" }]
          }
        ]
      }
    ]
  }
}
